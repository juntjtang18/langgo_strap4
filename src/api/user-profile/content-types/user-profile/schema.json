      "target": "plugin::users-permissions.user",
      "inversedBy": "user_profile"
    },
    "telephone": {
      "type": "string"
    },
    "baseLanguage": {
      "type": "string",
      "required": true
    },
    "proficiency": {
      "type": "string"
    },
    "reminder_enabled": {
      "type": "boolean"
    },
    "Bio": {
      "type": "string"
    },
    "avatar_img": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "visible_on_ladder": {
      "type": "boolean",
      "default": true
    }
  }
}
