      "required": true,
      "default": 0
    },
    "word_count": {
      "type": "integer",
      "required": true,
      "default": 0
    },
    "word_add": {
      "type": "integer",
      "required": true,
      "default": 0
    },
    "article_count": {
      "type": "integer",
      "required": true,
      "default": 0
    },
    "article_add": {
      "type": "integer",
      "required": true,
      "default": 0
    }
  }
