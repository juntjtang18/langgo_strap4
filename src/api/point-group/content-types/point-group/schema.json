{
  "kind": "collectionType",
  "collectionName": "point_groups",
  "info": {
    "singularName": "point-group",
    "pluralName": "point-groups",
    "displayName": "point group"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "group_rank": {
