      "target": "api::group-rank.group-rank",
      "inversedBy": "point_groups"
    },
    "group_no": {
      "type": "integer"
    },
    "user_point_groups": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-point-group.user-point-group",
