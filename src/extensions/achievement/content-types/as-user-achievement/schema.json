{
  "kind": "collectionType",
  "collectionName": "as_user_achievements",
  "info": {
    "singularName": "as-user-achievement",
    "pluralName": "as-user-achievements",
    "displayName": "AS User Achievement"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "userid": {
      "type": "string",
      "required": true
    },
    "username": {
      "type": "string"
    },
    "achievement": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::achievement.as-achievement",
      "inversedBy": "user_achievements"
    },
    "progress": {
      "type": "integer",
      "default": 0
    },
    "achieved": {
      "type": "boolean",
      "default": false
    },
    "achieved_at": {
      "type": "datetime"
    }
  }
}
