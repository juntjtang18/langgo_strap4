{
  "kind": "collectionType",
  "collectionName": "rs_groups",
  "info": {
    "singularName": "rs-group",
    "pluralName": "rs-groups",
    "displayName": "RS Group"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "rs_group_rule": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::rank-system.rs-group-rule",
      "inversedBy": "rs_groups"
    },
    "group_no": {
      "type": "integer"
    },
    "rs_group_rank": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::rank-system.rs-group-rank",
      "inversedBy": "rs_groups"
    },
    "rs_user_groups": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::rank-system.rs-user-group",
      "mappedBy": "rs_group"
    },
    "rs_user_snapshots": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::rank-system.rs-user-snapshot",
      "mappedBy": "rs_group"
    }
  }
}
